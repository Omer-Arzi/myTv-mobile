# Overrides .env for `expo export -p web` (npm run build:web), which loads
# in production mode — see .env.production.local > .env.local >
# .env.production > .env precedence (@expo/env's getEnvFiles). This is NOT
# a secret (it's the public API URL, visible in any browser network tab
# once deployed) and is committed, unlike .env/.env*.local.
EXPO_PUBLIC_API_BASE_URL=https://mytv-server-production.up.railway.app
